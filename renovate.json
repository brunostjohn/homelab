{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "argocd": {
    "fileMatch": ["apps/.+\\.y(a?)ml$"]
  },
  "kubernetes": {
    "fileMatch": ["k8s/.+\\.y(a?)ml$"],
    "ignorePaths": ["k8s/productivity/hoarder/meilisearch-deployment.yml"]
  },
  "separateMajorMinor": true,
  "packageRules": [
    {
      "description": "Immich: do not bump Helm chart; app images updated via customManagers",
      "matchManagers": ["argocd"],
      "matchDatasources": ["helm"],
      "matchDepNames": ["immich"],
      "enabled": false
    },
    {
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "automerge": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Immich server image tag inside Argo Helm values",
      "managerFilePatterns": ["/apps/clusterApps/templates/immich\\.yaml$/"],
      "matchStrings": [
        "(?m)^        image:\\n          tag: (?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)\\n\\n        immich:"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/immich-app/immich-server",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Immich machine-learning (CUDA) image tag inside Argo Helm values",
      "managerFilePatterns": ["/apps/clusterApps/templates/immich\\.yaml$/"],
      "matchStrings": [
        "(?m)^        machine-learning:\\n          image:\\n            tag: (?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+-cuda)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/immich-app/immich-machine-learning",
      "versioningTemplate": "semver"
    }
  ],
  "npm": {
    "ignorePaths": ["projects/homepage/**"]
  },
  "platformAutomerge": true
}
